# JARVIS Mission Control — Environment Variables
# Copy to .env and fill in values

# ============================================
# BASIC AUTH PROTECTION
# ============================================
# Set MC_AUTH_PASS to enable password protection on the dashboard.
# Leave blank for local development (auth disabled).
MC_AUTH_USER=architect
MC_AUTH_PASS=

# Optional: agent token to allow API access without basic auth
# (useful for OpenClaw agents calling the API)
MC_AGENT_TOKEN=

# ============================================
# GITHUB INTEGRATION
# ============================================
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# ============================================
# SERVER
# ============================================
PORT=3000
